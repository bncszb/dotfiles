// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "current_line_highlight": "gutter",
  "buffer_font_weight": 350.0,
  "buffer_font_family": "JetBrains Mono",
  "relative_line_numbers": "enabled",
  "title_bar": {
    "show_sign_in": false,
  },
  "colorize_brackets": true,
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "terminal": {
    "font_size": 13.0,
    "font_family": "MesloLGL Nerd Font Mono",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },

  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "autosave": "on_focus_change",

  "cli_default_open_behavior": "new_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "project_panel": {
    "dock": "left",
  },

  "languages": {
    "Python": {
      "language_servers": ["ty", "!basedpyright", "ruff"],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
  },
  "lsp": {
    "ruff": {
      "binary": {
        "path": ".venv/bin/ruff",
        "arguments": ["server"],
      },
    },
    "ty": {
      "binary": {
        "path": ".venv/bin/ty",
        "arguments": ["server"],
      },
    },
  },
}
